@page
@model AdminSiste.Pages.ModuloModel
@{
    ViewData["Title"] = "Módulos";
}

<div class="d-flex" style="min-width: 1200px;margin-top:100px;">
    <!-- Módulo lateral -->
    <aside class="bg-light border-end" style="width: 250px; min-height: 100vh;">
        <ul class="nav flex-column p-3">
            <li class="nav-item"><a class="nav-link" href="#introducao">Introdução</a></li>
            <li class="nav-item"><a class="nav-link" href="#conceitos">Conceitos básicos</a></li>
            <li class="nav-item"><a class="nav-link" href="#estrutura">Estrutura do programa</a></li>
            <li class="nav-item"><a class="nav-link" href="#tipos">Sistema de tipos</a></li>
            <li class="nav-item"><a class="nav-link" href="#poo">Programação orientada a objeto</a></li>
            <li class="nav-item"><a class="nav-link" href="#funcionais">Técnicas funcionais</a></li>
            <li class="nav-item"><a class="nav-link" href="#erros">Exceções e erros</a></li>
            <li class="nav-item"><a class="nav-link" href="#estilo">Estilo de codificação</a></li>
            <li class="nav-item"><a class="nav-link" href="#tutoriais">Tutoriais</a></li>
            <li class="nav-item"><a class="nav-link" href="#novidades">Novidades no C#</a></li>
        </ul>
    </aside>

    <!-- Conteúdo principal -->
    <main class="flex-grow-1 p-4" style="overflow-y: auto; height: 100vh;">
        <section id="introducao">
            <h2>Introdução</h2>
            <p>Conteúdo introdutório sobre C#...</p>
        </section>
        <section id="conceitos">
            <h2>Conceitos básicos</h2>
            <p>Explicação dos conceitos fundamentais...</p>
        </section>
        <section id="estrutura">
            <h2>Estrutura do programa</h2>
            <p>Detalhes sobre a estrutura de um programa em C#...</p>
        </section>
        <section id="tipos">
            <h2>Sistema de tipos</h2>
            <p>Descrição do sistema de tipos do C#...</p>
        </section>
        <section id="poo">
            <h2>Programação orientada a objeto</h2>
            <p>Explicação sobre classes, objetos e herança...</p>
        </section>
        <section id="funcionais">
            <h2>Técnicas funcionais</h2>
            <p>Uso de funções, lambdas e LINQ...</p>
        </section>
        <section id="erros">
            <h2>Exceções e erros</h2>
            <p>Tratamento de erros e exceções em C#...</p>
        </section>
        <section id="estilo">
            <h2>Estilo de codificação</h2>
            <p>Boas práticas de escrita de código...</p>
        </section>
        <section id="tutoriais">
            <h2>Tutoriais</h2>
            <p>Links e exemplos práticos...</p>
        </section>
        <section id="novidades">
            <h2>Novidades no C#</h2>
            <p>Recursos recentes e atualizações da linguagem...</p>
        </section>
    </main>
</div>
