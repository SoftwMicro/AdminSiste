@page
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    <h2 class="text-center text-primary">Ambiente Aprendizado</h2>
    <p class="text-center">
        Bem-vindo ao painel administrativo. Aqui você encontra recursos e atalhos.
    </p>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">📘 Introdução</h5>
                    <p class="card-text">Tour</p>
                    <a href="#" class="btn btn-outline-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">💡 Conceitos</h5>
                    <p class="card-text">Conceitos básicos</p>
                    <a href="#" class="btn btn-outline-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">🆕 Novidades</h5>
                    <p class="card-text">Recursos e atualizações</p>
                    <a href="#" class="btn btn-outline-primary">Acessar</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">🎥 Vídeos</h5>
                    <p class="card-text">Série Aprenda AO VIVO</p>
                    <a href="#" class="btn btn-outline-primary">Assistir</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">📚 Treinamento</h5>
                    <p class="card-text">DevOps integração com Agentes de IA</p>
                    <a href="#" class="btn btn-outline-primary">Iniciar</a>
                </div>
            </div>
        </div>
    </div>
</div>
