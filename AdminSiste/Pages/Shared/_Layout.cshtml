<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdminSiste</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/AdminSiste.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <style>
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1050;
        }
        body.auth-bg {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            padding-top: 56px; /* altura padrão do navbar bootstrap */
        }
        .auth-container {
            flex: 1 0 auto;
        }
    </style>
</head>
<body class="auth-bg">
    @if (User?.Identity?.IsAuthenticated ?? false)
    {
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
                <div class="container-fluid">
                    <a class="navbar-brand" href="/Dashboard">AdminSiste</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarMenu">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="conceitosDropdown" role="button" data-bs-toggle="dropdown">
                                    Curso - DevOps Agentes IA
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="Modulo">Modúlo 1</a></li>
                                    <li><a class="dropdown-item" href="#">Conceitos básicos</a></li>
                                    <li><a class="dropdown-item" href="#">Novidades</a></li>
                                </ul>
                            </li>
                            <li class="nav-item"><a class="nav-link" href="#">Recursos</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">Referência</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">Especificações</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">códigos fonte</a></li>

                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item"><a class="nav-link" href="/Logout">Sair</a></li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }
    <div class="auth-container" id="auth-container">
     @RenderBody()
    </div>
   @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/login.js"></script>
</body>
</html>
